# frozen_string_literal: true

require "fileutils"
require "json"
require "open3"
require "rake"
require "shellwords"

module BrewRsTasks
  module_function

  ROOT = Pathname(__dir__).join("../../../..").realpath.freeze
  RUST_DIR = Pathname(__dir__).realpath.freeze
  BREW = (ROOT/"bin/brew").to_s.freeze
  BENCHMARK_MAX_SLOWDOWN = 1.25

  def brew_executable
    prefix_brew = ROOT.parent/"bin/brew"
    prefix_brew.executable? ? prefix_brew.to_s : BREW
  end

  def executable_on_path?(command)
    ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).any? do |directory|
      path = File.join(directory, command)
      File.file?(path) && File.executable?(path)
    end
  end

  def run_command(*command, env: {}, chdir: ROOT)
    success = Dir.chdir(chdir) do
      system(env, *command, exception: false)
    end

    return if success

    raise "Command failed: #{Shellwords.join(command)}"
  end

  def capture_command(*command, env: {}, chdir: ROOT)
    output, status = Dir.chdir(chdir) do
      Open3.capture2e(env, *command)
    end

    return output.strip if status.success?

    raise "Command failed: #{Shellwords.join(command)}\n#{output}"
  end

  def shell_command(*command, env: {})
    env_unsets = []
    env_assignments = []

    env.each do |key, value|
      if value.nil?
        env_unsets += ["-u", key]
      else
        env_assignments << "#{key}=#{value}"
      end
    end

    Shellwords.join(["env"] + env_unsets + env_assignments + command)
  end

  def frontend_env
    {
      "HOMEBREW_DEVELOPER"                  => "1",
      "HOMEBREW_EXPERIMENTAL_RUST_FRONTEND" => "1",
    }
  end

  def benchmark_env(current_prefix:, default_prefix:)
    env = {
      "HOMEBREW_DEVELOPER"                  => "1",
      "HOMEBREW_EXPERIMENTAL_RUST_FRONTEND" => nil,
      "HOMEBREW_NO_AUTO_UPDATE"             => "1",
      "HOMEBREW_NO_INSTALL_CLEANUP"         => "1",
      "HOMEBREW_NO_INSTALL_FROM_API"        => nil,
    }
    env["HOMEBREW_INTEGRATION_TEST"] = "1" if current_prefix != default_prefix
    env
  end

  def default_prefix
    system_name = capture_command("uname", "-s")
    machine = capture_command("uname", "-m")

    if system_name == "Darwin" && machine == "arm64"
      "/opt/homebrew"
    elsif system_name == "Linux"
      "/home/linuxbrew/.linuxbrew"
    else
      "/usr/local"
    end
  end

  def run_benchmark(title, ruby_command:, rust_command:, prepare: nil, cleanup: nil, runs: 3, warmup: 1,
                    export_json: nil)
    command = ["hyperfine", "--runs", runs.to_s, "--warmup", warmup.to_s]
    command += ["--prepare", prepare] if prepare
    command += ["--cleanup", cleanup] if cleanup
    command += ["--export-json", export_json.to_s] if export_json
    command += [ruby_command, rust_command]

    puts
    puts "==> #{title}"
    run_command(*command)

    return if export_json.nil?

    JSON.parse(Pathname(export_json).read).fetch("results")
  rescue RuntimeError
    {
      "Ruby" => ruby_command,
      "Rust" => rust_command,
    }.each do |label, benchmark_command|
      puts
      puts "==> #{title} (#{label} debug)"
      system("bash", "-lc", benchmark_command, exception: false)
    end

    raise
  end

  def benchmark_suite(common_env:, rust_env:)
    list_formula = begin
      capture_command(brew_executable, "list", "--versions", "rust", env: common_env).split.first
    rescue RuntimeError
      nil
    end
    list_formula ||= capture_command(brew_executable, "list", env: common_env).lines.first.to_s.strip
    abort "brew list benchmarks require at least one installed formula" if list_formula.empty?
    list_slug = list_formula.gsub(/[^A-Za-z0-9.+@_-]+/, "-")

    [
      {
        slug:         "search-jq",
        title:        "brew search jq",
        ruby_command: shell_command(brew_executable, "search", "jq", env: common_env),
        rust_command: shell_command(brew_executable, "search", "jq", env: rust_env),
        runs:         5,
        warmup:       2,
      },
      {
        slug:         "list-#{list_slug}",
        title:        "brew list #{list_formula}",
        ruby_command: shell_command(brew_executable, "list", list_formula, env: common_env),
        rust_command: shell_command(brew_executable, "list", list_formula, env: rust_env),
        runs:         5,
        warmup:       2,
      },
    ]
  end

  def benchmark_context
    abort "hyperfine is required. Install it with: brew install hyperfine" unless executable_on_path?("hyperfine")

    binary_path = ROOT/"Library/Homebrew/vendor/brew-rs/brew-rs"
    Rake::Task["build"].invoke unless binary_path.executable?
    abort "Rust frontend binary is missing at #{binary_path}" unless binary_path.executable?

    current_prefix = capture_command(brew_executable, "--prefix")
    current_default_prefix = default_prefix
    common_env = benchmark_env(
      current_prefix: current_prefix,
      default_prefix: current_default_prefix,
    )
    rust_env = common_env.merge("HOMEBREW_EXPERIMENTAL_RUST_FRONTEND" => "1")

    [
      benchmark_suite(
        common_env: common_env,
        rust_env:   rust_env,
      ),
      BENCHMARK_MAX_SLOWDOWN,
    ]
  end

  def benchmark_markdown_row(title:, ruby_mean:, rust_mean:, max_slowdown:)
    slowdown = ruby_mean.zero? ? Float::INFINITY : rust_mean / ruby_mean
    status = (slowdown <= max_slowdown) ? "PASS" : "FAIL"

    {
      title:    title,
      slowdown: slowdown,
      status:   status,
      markdown: "| #{title} | #{format("%.3f s", ruby_mean)} | #{format("%.3f s", rust_mean)} | " \
                "#{format("%.2fx", slowdown)} | #{status} |",
    }
  end

  def write_benchmark_summary(rows, output_dir)
    summary = [
      "# brew-rs benchmark summary",
      "",
      "| Benchmark | Ruby mean | Rust mean | Rust/Ruby | Status |",
      "| --- | ---: | ---: | ---: | --- |",
      *rows.map { |row| row.fetch(:markdown) },
      "",
    ].join("\n")

    File.write(output_dir/"summary.md", summary)
    File.write(output_dir/"summary.json", JSON.pretty_generate(rows))

    return unless ENV["GITHUB_STEP_SUMMARY"]

    File.open(ENV.fetch("GITHUB_STEP_SUMMARY"), "a") { |file| file.puts(summary) }
  end
end

desc "Build and vendor brew-rs through Homebrew vendor-install"
task :build do
  BrewRsTasks.run_command(BrewRsTasks.brew_executable, "vendor-install", "brew-rs", env: BrewRsTasks.frontend_env)
end

desc "Benchmark brew-rs against the existing frontend"
task :benchmark do
  benchmarks, = BrewRsTasks.benchmark_context

  benchmarks.each do |benchmark|
    BrewRsTasks.run_benchmark(
      benchmark.fetch(:title),
      ruby_command: benchmark.fetch(:ruby_command),
      rust_command: benchmark.fetch(:rust_command),
      prepare:      benchmark[:prepare],
      cleanup:      benchmark[:cleanup],
      runs:         benchmark.fetch(:runs),
      warmup:       benchmark.fetch(:warmup),
    )
  end
end

namespace :benchmark do
  desc "Benchmark brew-rs and fail if Rust regresses against Ruby"
  task :check do
    benchmarks, max_slowdown = BrewRsTasks.benchmark_context
    output_dir = BrewRsTasks::RUST_DIR/"benchmark-results"
    FileUtils.rm_rf(output_dir)
    FileUtils.mkdir_p(output_dir)
    rows = benchmarks.map do |benchmark|
      results = BrewRsTasks.run_benchmark(
        benchmark.fetch(:title),
        ruby_command: benchmark.fetch(:ruby_command),
        rust_command: benchmark.fetch(:rust_command),
        prepare:      benchmark[:prepare],
        cleanup:      benchmark[:cleanup],
        runs:         benchmark.fetch(:runs),
        warmup:       benchmark.fetch(:warmup),
        export_json:  output_dir.join("#{benchmark.fetch(:slug)}.json"),
      )
      ruby_result, rust_result = results

      BrewRsTasks.benchmark_markdown_row(
        title:        benchmark.fetch(:title),
        ruby_mean:    ruby_result.fetch("mean"),
        rust_mean:    rust_result.fetch("mean"),
        max_slowdown: max_slowdown,
      )
    end

    BrewRsTasks.write_benchmark_summary(rows, output_dir)

    failures = rows.select { |row| row.fetch(:status) == "FAIL" }
    if failures.any?
      abort "brew-rs benchmark regressions exceeded #{format("%.2fx", max_slowdown)}: " \
            "#{failures.map { |row| row.fetch(:title) }.join(", ")}"
    end
  end
end

desc "Stage brew-rs into another Homebrew checkout and build it there"
task :stage do
  repository = Pathname(ENV.fetch("BREW_RS_STAGE_REPOSITORY")).realpath

  FileUtils.install(
    BrewRsTasks::ROOT/"Library/Homebrew/brew.sh",
    repository/"Library/Homebrew/brew.sh",
    mode: 0644,
  )
  FileUtils.install(
    BrewRsTasks::ROOT/"Library/Homebrew/cmd/vendor-install.sh",
    repository/"Library/Homebrew/cmd/vendor-install.sh",
    mode: 0755,
  )
  FileUtils.mkdir_p(repository/"Library/Homebrew/rust")
  FileUtils.rm_rf(repository/"Library/Homebrew/rust/brew-rs")
  BrewRsTasks.run_command(
    "rsync",
    "-a",
    "--delete",
    "--exclude",
    "target",
    "#{BrewRsTasks::RUST_DIR}/",
    "#{repository}/Library/Homebrew/rust/brew-rs/",
  )
  BrewRsTasks.run_command(
    (repository/"bin/brew").to_s,
    "vendor-install",
    "brew-rs",
    env:   BrewRsTasks.frontend_env,
    chdir: repository,
  )
end
